SELECT *
FROM (SELECT r.*, ROWNUM RNUM, COUNT(*) OVER () RESULT_COUNT
      FROM (SELECT PLA.ID_EXT_PER                               as        cc,
                   substr(B.NRO_CUENTA, 5, 16)                            tarjeta,
                   B.NOM_CLIENTE                                          nombre,
                   -(PLA.SAL_ACT_RETIRO_EFECTIVO + PLA.SAL_ACT_MERCANCIA) saldo,
                   to_char(PLA.FEC_ULT_ACTIVIDAD, 'DD/MM/YYYY') as        fecha
