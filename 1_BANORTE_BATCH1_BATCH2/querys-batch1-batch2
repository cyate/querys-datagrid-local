-- #############################################################################
-- # PARTE 1: CREACI?N DE LA FUNCI?N REUTILIZABLE                           #
-- #############################################################################
-- Esta funci?n encapsula toda la l?gica de validaci?n.
-- Recibe una fecha en formato 'MMYY' y devuelve 'Aplica' o 'No Aplica'.

CREATE OR REPLACE FUNCTION NOVO04005.VALIDAR_EXPIRACION (
    p_fec_expira IN VARCHAR2
) RETURN VARCHAR2
IS
    v_fecha_expiracion DATE;
    v_fecha_actual     DATE := SYSDATE;
    v_meses_diferencia NUMBER;
BEGIN
    -- PASO 1: Convertir el texto 'MMYY' a una fecha de Oracle.
    -- Usamos TRUNC(..., 'MM') para asegurarnos de comparar solo los meses,
    -- ignorando los d?as y la hora. El formato 'MMRR' interpreta correctamente
    -- los a?os de dos d?gitos (ej. '25' -> 2025, '99' -> 1999).
    v_fecha_expiracion := TRUNC(TO_DATE(p_fec_expira, 'MMRR'), 'MM');

    -- PASO 2: Calcular la diferencia exacta de meses entre el inicio del mes
    -- de expiraci?n y el inicio del mes actual.
    v_meses_diferencia := MONTHS_BETWEEN(v_fecha_expiracion, TRUNC(v_fecha_actual, 'MM'));

    -- PASO 3: Aplicar la regla de negocio.
    -- La diferencia debe ser -1 (mes pasado), 0 (mes actual), o 1 (mes pr?ximo).
    IF v_meses_diferencia BETWEEN -1 AND 1 THEN
        -- Adicionalmente, verificamos que la tarjeta no haya expirado realmente.
        -- LAST_DAY obtiene el ?ltimo d?a del mes de expiraci?n.
        IF LAST_DAY(v_fecha_expiracion) < TRUNC(v_fecha_actual) THEN
            RETURN 'No Aplica (Expir?)';
        ELSE
            RETURN 'Aplica';
        END IF;
    ELSE
        RETURN 'No Aplica';
    END IF;

EXCEPTION
    -- Si el formato de 'p_fec_expira' es incorrecto (ej. 'ABCD'),
    -- TO_DATE fallar?. Capturamos el error y devolvemos 'No Aplica'.
    WHEN OTHERS THEN
        RETURN 'No Aplica (Formato Inv?lido)';
END VALIDAR_EXPIRACION;
/
COMMIT;
