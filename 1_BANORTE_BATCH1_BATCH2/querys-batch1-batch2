                 MAS_CUENTA_VW c
            where c.ID_EXT_EMP = '1016481553'
              and ((a.SUBBIN BETWEEN 41892810 AND 41892810))
              and a.ESTATUS in (1, 2)
              and a.FECHBAJA is null
              and c.FECEXPIRA <> '0000'
              and c.COD_MISCELANEO2 in ('AF', 'SA')
              and a.NROCUENTAID = c.NROCUENTAID) a
      where ROWNUM <= (0 + 10))
where rnum > 0;


