SELECT "NRO_ORGANIZACION", "NRO_TIPO", "NRO_CUENTA", "FEC_TRANSACCION", "COD_TRANSACCION", "MON_TRANSACCION", "FEC_POSTEO", "CATEGORIA", "COD_ORIGEN", "REF_INTERNA", "NOMBRE_CIUDAD_EDO", "FEC_REG",   "COD_MONEDA_ORIGEN", "MONTO_MONEDA_ORIGEN", "NRO_TARJETA", "EST_CONCILIACION", "SIGNO", "FEC_CONCILIACION", "TIPO_MSJ", "AUTH_CODE", "COD_COMERCIO", "EST_TRANSACCION"
  FROM
    (
        /*TRANSACCIONES AUTORIZADAS DE RECARGAS ONLINE, RECARGAS TRANSF MAESTRA, CARGOS TRANSF MAESTRA, RETIROS ATM Y COMPRAS PRESENTES/NO PRESENTES EXTRAIDAS DEL ISO PERSISTER*/
        SELECT
          NRO_ORGANIZACION,
          100 AS NRO_TIPO,
          LPAD(NRO_TARJETA,20,'0') AS NRO_CUENTA,
          DECODE(CATEGORIA,'9999',((FEC_REG)) , FEC_REG) AS FEC_TRANSACCION,
          /*05.04.22: NUEVO MAPEO DE CODIGO DE TRANSACCION PARA DEVOLUCIONES*/
          DECODE(COD_TRANSACCION||DECODE(SUBSTR(TIPO_MSJ,0,2),'96','0620','95','0220','94','0420','92','0200','91','0100'), '200220','20', '210200','20', '220200','20', '000200','40', '000100','40', '020200','40', '110200','40', '000420','41', '020420','41', '200420','27', '210420','27', '200200','41', '310200','95', '010200','30', '010420','31') AS COD_TRANSACCION,
          MON_TRANSACCION*100 AS MON_TRANSACCION,
          NULL AS FEC_POSTEO,
          CATEGORIA,
          NULL AS COD_ORIGEN,
          TO_CHAR(REF_INTERNA) AS REF_INTERNA,
          NOMBRE_COMERCIO AS NOMBRE_CIUDAD_EDO,
          FEC_REG,
          COD_MONEDA_ORIGEN,
          MON_TRANSACCION*100      AS MONTO_MONEDA_ORIGEN,
          LPAD(NRO_TARJETA,20,'0') AS NRO_TARJETA,
          'PC'                     AS EST_CONCILIACION,
          CASE
            WHEN (COD_TRANSACCION >=20 AND SUBSTR(TIPO_MSJ,0,2) = '94')  THEN '-'
            WHEN (COD_TRANSACCION >=20 AND SUBSTR(TIPO_MSJ,0,2) <> '94')THEN '+'
            WHEN (COD_TRANSACCION <20 AND SUBSTR(TIPO_MSJ,0,2) <> '94')  THEN '-'
            WHEN (COD_TRANSACCION <20 AND SUBSTR(TIPO_MSJ,0,2) = '94')  THEN '+'
            ELSE '-'
          END AS SIGNO,
          NULL AS FEC_CONCILIACION,
          TIPO_MSJ||COD_TRANSACCION||'' AS TIPO_MSJ,
          AUTH_CODE,
          COD_COMERCIO,
          'EN PROCESO' AS EST_TRANSACCION
        FROM
          NOVO04005.TEMP_DETALLE_TRX_ONLINE
        WHERE
          (FLAG = '0' OR FLAG IS NULL)
          AND MON_TRANSACCION <> 0
          AND RC='00'
          AND TIPO_MSJ <> '9420'
          AND NRO_TARJETA = '4189281060183291');



