from (select rownum rnum, a.*
      from (select a.NROPLASTICOID,
                   a.NOMCLIENTE,
                   a.ID_EXT_PER,
                   c.FECEXPIRA,
                   CASE
                       when (to_number(substr(c.FECEXPIRA, 3, 2) || substr(c.FECEXPIRA, 1, 2)) <
                             to_number(to_char(sysdate, 'YYMM'))) then '99'
                       when (BLOQUE = '43') then '43'
                       when (BLOQUE = '41') then '41'
                       when (BLOQUE = 'PB') then 'PB'
                       when (BLOQUE IN ('00', '  ', '')) then ''
                       else '' END AS BLOQUE
